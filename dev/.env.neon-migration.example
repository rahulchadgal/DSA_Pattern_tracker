# Source Aiven database.
# Use one complete Postgres URL, or the JDBC compatibility vars below.
AIVEN_DATABASE_URL="postgresql://USER:PASSWORD@AIVEN_HOST:AIVEN_PORT/DB_NAME?sslmode=require"

# Optional compatibility if copying from the old Aiven setup.
# AIVEN_DB_URL="jdbc:postgresql://AIVEN_HOST:AIVEN_PORT/DB_NAME?ssl=require"
# AIVEN_DB_USERNAME="USER"
# AIVEN_DB_PASSWORD="PASSWORD"

# Neon restore should use the direct connection string.
# Use the pooled connection string only for Vercel production DATABASE_URL.
NEON_DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@NEON_DIRECT_HOST/DB_NAME?sslmode=require"
NEON_POOLED_DATABASE_URL="postgresql://USER:PASSWORD@NEON_POOLED_HOST/DB_NAME?sslmode=require"

# Temporary local dump path. This file is ignored by git.
MIGRATION_DUMP_FILE="dev/aiven-to-neon.dump"
