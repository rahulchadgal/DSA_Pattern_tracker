# Preferred for Vercel serverless functions
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=require

# Optional compatibility (your existing JDBC-style value also works)
# DB_URL=jdbc:postgresql://HOST:PORT/DB_NAME?ssl=require&user=USER&password=PASSWORD
# DB_URL=jdbc:postgresql://HOST:PORT/DB_NAME?ssl=require
# DB_USERNAME=USER
# DB_PASSWORD=PASSWORD

# Pooling is off by default to avoid holding direct connections open on small DB plans.
# Enable PG_USE_POOL only when DATABASE_URL points to the Aiven pooler/PgBouncer URL.
# If DATABASE_URL is the direct Aiven database URL, leave PG_USE_POOL unset or false.
# PG_USE_POOL=true
PG_POOL_MAX=1
PG_CONNECTION_TIMEOUT_MS=5000
PG_IDLE_TIMEOUT_MS=1000

# Vercel Cron keepalive protection
CRON_SECRET=change-me
