# Preferred for Vercel serverless functions with manual Neon/Aiven switching.
# Normal app traffic uses DB_PROVIDER. The admin sync button copies the active
# provider into the inactive provider.
DB_PROVIDER=neon
NEON_DATABASE_URL=postgresql://USER:PASSWORD@NEON_POOLED_HOST/DB_NAME?sslmode=require
AIVEN_DATABASE_URL=postgresql://USER:PASSWORD@AIVEN_HOST:AIVEN_PORT/DB_NAME?sslmode=require

# Backward-compatible fallback for the active provider if provider-specific
# env vars are not set.
DATABASE_URL=postgresql://USER:PASSWORD@NEON_POOLED_HOST/DB_NAME?sslmode=require

# Optional compatibility (your existing JDBC-style value also works)
# DB_URL=jdbc:postgresql://HOST:PORT/DB_NAME?ssl=require&user=USER&password=PASSWORD
# DB_URL=jdbc:postgresql://HOST:PORT/DB_NAME?ssl=require
# DB_USERNAME=USER
# DB_PASSWORD=PASSWORD

# Enable PG_USE_POOL only when DATABASE_URL points to a pooled/PgBouncer URL.
# For Neon production on Vercel, use the pooled URL and keep this true.
PG_USE_POOL=true
PG_POOL_MAX=1
PG_CONNECTION_TIMEOUT_MS=5000
PG_IDLE_TIMEOUT_MS=1000

# Vercel Cron keepalive protection
CRON_SECRET=change-me
