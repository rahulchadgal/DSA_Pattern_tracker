# Preferred for Vercel serverless functions after Neon migration.
# Use Neon's pooled connection string here.
DATABASE_URL=postgresql://USER:PASSWORD@NEON_POOLED_HOST/DB_NAME?sslmode=require

# Optional compatibility (your existing JDBC-style value also works)
# DB_URL=jdbc:postgresql://HOST:PORT/DB_NAME?ssl=require&user=USER&password=PASSWORD
# DB_URL=jdbc:postgresql://HOST:PORT/DB_NAME?ssl=require
# DB_USERNAME=USER
# DB_PASSWORD=PASSWORD

# Enable PG_USE_POOL only when DATABASE_URL points to a pooled/PgBouncer URL.
# For Neon production on Vercel, use the pooled URL and keep this true.
PG_USE_POOL=true
PG_POOL_MAX=1
PG_CONNECTION_TIMEOUT_MS=5000
PG_IDLE_TIMEOUT_MS=1000

# Vercel Cron keepalive protection
CRON_SECRET=change-me
