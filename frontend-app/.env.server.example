# Preferred for Vercel serverless functions
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=require

# Optional compatibility (your existing JDBC-style value also works)
# DB_URL=jdbc:postgresql://HOST:PORT/DB_NAME?ssl=require&user=USER&password=PASSWORD

# Optional pool tuning
PG_POOL_MAX=10

# Company bank sync API protection
COMPANY_SYNC_SECRET=change-me

# Optional company sync controls
# COMPANY_BANK_REPO_URL=https://github.com/rahulchadgal/leetcode-companywise-interview-questions.git
# COMPANY_BANK_REPO_BRANCH=master
# COMPANY_BANK_REPO_CACHE_DIR=/tmp/leetcode-companywise-interview-questions
# COMPANY_SYNC_COOLDOWN_MS=120000
